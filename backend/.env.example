# ── WHOOP OAuth ──────────────────────────────────────
WHOOP_CLIENT_ID=your-client-id
WHOOP_CLIENT_SECRET=your-client-secret
# Same domain as the app (Railway URL)
WHOOP_REDIRECT_URI=https://your-app.railway.app/auth/callback

# ── Server ────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Security ─────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-generate-with-openssl-rand-hex-32

# ── Database ─────────────────────────────────────────
# Railway persistent volume must be mounted at /data
DB_PATH=/data/pulseiq.db
